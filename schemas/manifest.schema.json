{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "okf-vault-manifest/1.0.0",
  "title": "OKF Vault Ingestion Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "note_contract_version", "sources"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "okf-vault-manifest/1.0.0"
    },
    "note_contract_version": {
      "type": "string",
      "pattern": "^okf-note-contract/[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRecord"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "vaultRelativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)[a-zA-Z0-9_./-]+$"
    },
    "sourceSpanPath": {
      "type": "string",
      "pattern": "^references/sources/[a-zA-Z0-9_-]+/span-[a-zA-Z0-9_-]+\\.md$"
    },
    "sourceSpanProfile": {
      "type": "string",
      "enum": ["article", "video", "panel", "deck"]
    },
    "sourceSpanExpansion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["previous", "next"],
      "properties": {
        "previous": {
          "type": "integer",
          "const": 1
        },
        "next": {
          "type": "integer",
          "const": 1
        }
      }
    },
    "sourceSpanRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "sha256", "profile", "sequence", "anchor_ids"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        },
        "path": {
          "$ref": "#/$defs/sourceSpanPath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "profile": {
          "$ref": "#/$defs/sourceSpanProfile"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "anchor_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "prev_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        },
        "next_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        }
      }
    },
    "sourceSpanIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "profile", "default_expansion", "spans"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "okf-source-spans/1.0.0"
        },
        "profile": {
          "$ref": "#/$defs/sourceSpanProfile"
        },
        "default_expansion": {
          "$ref": "#/$defs/sourceSpanExpansion"
        },
        "spans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceSpanRef"
          }
        }
      }
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_key",
        "kind",
        "origin",
        "content_sha256",
        "contract_version",
        "status",
        "processed_at"
      ],
      "properties": {
        "source_key": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["local", "google_drive", "granola", "youtube"]
        },
        "origin": {
          "type": "string",
          "minLength": 1
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "contract_version": {
          "type": "string",
          "pattern": "^okf-note-contract/[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "note_path": {
          "$ref": "#/$defs/vaultRelativePath"
        },
        "status": {
          "type": "string",
          "enum": ["committed", "skipped"]
        },
        "skip_reason": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 7
        },
        "source_span_index": {
          "$ref": "#/$defs/sourceSpanIndex"
        },
        "processed_at": {
          "$ref": "#/$defs/utcTimestamp"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "skipped"
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["skip_reason"],
            "properties": {
              "skip_reason": {
                "type": "string",
                "minLength": 1
              },
              "source_span_index": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "committed"
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["note_path", "commit"],
            "properties": {
              "note_path": {
                "$ref": "#/$defs/vaultRelativePath"
              },
              "commit": {
                "type": "string",
                "minLength": 7
              }
            }
          }
        }
      ]
    }
  }
}
