{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "okf-vault-proposal/1.0.0",
  "title": "OKF Vault Curation Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_id",
    "type",
    "affected_paths",
    "rationale",
    "confidence",
    "disposition"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "okf-vault-proposal/1.0.0"
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["topic", "link", "duplicate", "contradiction"]
    },
    "affected_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/vaultRelativePath"
      }
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^claim-[0-9]{3}$"
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "suggested_changes": {
      "type": "string"
    },
    "disposition": {
      "type": "string",
      "enum": ["pending", "accepted", "rejected", "resolved"]
    },
    "curator_comment": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["duplicate", "contradiction"]
          }
        }
      },
      "then": {
        "required": ["claim_ids"],
        "properties": {
          "claim_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^claim-[0-9]{3}$"
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "vaultRelativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)[a-zA-Z0-9_./-]+$"
    }
  }
}
