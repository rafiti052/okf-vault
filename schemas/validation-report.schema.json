{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "okf-vault-validation-report/1.0.0",
  "title": "OKF Vault Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_version", "status", "summary", "issues"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "okf-vault-validation-report/1.0.0"
    },
    "contract_version": {
      "type": "string",
      "pattern": "^okf-note-contract/[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    }
  },
  "$defs": {
    "vaultRelativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)[a-zA-Z0-9_./-]+$"
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/vaultRelativePath"
        }
      }
    }
  }
}
